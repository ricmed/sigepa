# ============================================================
# SIGEPA - Variáveis de Ambiente - PRODUÇÃO (EXEMPLO)
# ⚠️  Crie uma cópia deste arquivo com o nome .env.prod
# e preencha as variáveis marcadas como OBRIGATÓRIO
# ============================================================

# --- OBRIGATÓRIO ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=sua-chave-secreta-muito-segura-aqui
ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
DB_PASSWORD=sua-senha-segura-do-banco

# --- OPCIONAL (Banco de Dados) ---
# Têm valores padrão ou são definidos no docker-compose
DB_NAME=
DB_USER=
DB_HOST=
DB_PORT=
APP_PORT=8000

# --- OPCIONAL (E-mail) ---
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_HOST_USER=seu-email@gmail.com
#EMAIL_HOST_PASSWORD=sua-senha-de-app-do-email
#DEFAULT_FROM_EMAIL=noreply@seudominio.com.br

# --- OPCIONAL (Segurança / HTTPS) ---
# Descomente e altere para True quando usar HTTPS (SSL) sem isso por Default é False
#SECURE_SSL_REDIRECT=True
#SESSION_COOKIE_SECURE=True
#CSRF_COOKIE_SECURE=True
#CSRF_TRUSTED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# --- OPCIONAL (Cache - Redis) ---
#REDIS_URL=redis://redis:6379/1
